OPENAI_API_KEY=your_openai_api_key_here
SYNOPSE_OPENAI_MODEL=gpt-4o-mini
SYNOPSE_OPENAI_TIMEOUT_SECONDS=30
# SYNOPSE_OPENAI_BASE_URL=

# Executor selection:
# - enable exactly one executor for the cleanest behavior
# - if both are enabled, Synopse prefers ACPX over direct Codex

# Recommended: ACPX-backed execution
SYNOPSE_ACPX_EXECUTOR_ENABLED=true
SYNOPSE_ACPX_COMMAND=acpx
# For a repo-local acpx checkout instead of a global install:
# SYNOPSE_ACPX_COMMAND=node /absolute/path/to/acpx/dist/cli.js
SYNOPSE_ACPX_AGENT=codex
SYNOPSE_ACPX_PERMISSION_MODE=approve-all
SYNOPSE_ACPX_NON_INTERACTIVE_PERMISSIONS=deny
# SYNOPSE_ACPX_TIMEOUT_SECONDS=300

# Legacy direct Codex executor
SYNOPSE_CODEX_EXECUTOR_ENABLED=false
# SYNOPSE_CODEX_COMMAND=codex
