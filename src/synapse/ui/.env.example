# Public HTTPS base URL for the main Synapse backend when this UI is deployed
# on a different origin, such as Vercel. Use the backend origin itself, not a
# route like /sessions, and make sure that origin also supports secure
# websocket upgrades for /sessions/{session_id}/stream. Leave unset for local
# same-origin / Vite proxy development.
VITE_API_BASE_URL=https://your-synapse-backend.example.com
